import React, { useState, useEffect } from 'react';
import { Compass, Play, Square, RotateCcw, Activity, Smartphone, AlertTriangle, Settings2 } from 'lucide-react';

export default function App() {
  const [step, setStep] = useState('intro'); // 'intro', 'measuring', 'result'
  const [hasPermission, setHasPermission] = useState(false);
  const [sensorStatus, setSensorStatus] = useState('waiting'); // 'waiting', 'active', 'blocked'
  const [errorMessage, setErrorMessage] = useState('');
  
  const [isTracking, setIsTracking] = useState(false);
  const [currentHeading, setCurrentHeading] = useState(0);
  const [startHeading, setStartHeading] = useState(null);
  const [angleDiff, setAngleDiff] = useState(0);
  const [maxAngle, setMaxAngle] = useState(0);

  // Mode manuel si les capteurs sont bloqués
  const [isSimulating, setIsSimulating] = useState(false);

  const requestAccess = async () => {
    setErrorMessage('');
    try {
      // Pour les iPhones récents (iOS 13+) qui demandent une permission explicite
      if (typeof DeviceOrientationEvent !== 'undefined' && typeof DeviceOrientationEvent.requestPermission === 'function') {
        const permissionState = await DeviceOrientationEvent.requestPermission();
        if (permissionState === 'granted') {
          setHasPermission(true);
          setStep('measuring');
        } else {
          setErrorMessage("L'accès aux capteurs a été refusé par votre téléphone.");
        }
      } else {
        // Pour Android, PC, ou anciens appareils
        setHasPermission(true);
        setStep('measuring');
      }
    } catch (error) {
      // Souvent déclenché si on est dans une Iframe restreinte
      setErrorMessage("Impossible d'activer les capteurs ici. " + error.message);
      setHasPermission(true);
      setStep('measuring');
    }
  };

  const calculateAngleDifference = (start, current) => {
    if (start === null) return 0;
    let diff = current - start;
    while (diff <= -180) diff += 360;
    while (diff > 180) diff -= 360;
    return Math.abs(Math.round(diff));
  };

  useEffect(() => {
    if (!hasPermission || isSimulating) return;

    let timeoutId;

    const handleOrientation = (event) => {
      let heading;
      if (event.webkitCompassHeading !== undefined) {
        heading = event.webkitCompassHeading; // iOS
      } else if (event.alpha !== null) {
        heading = 360 - event.alpha; // Android
      } else {
        return; // Pas de données valides
      }

      setSensorStatus('active');
      setCurrentHeading(heading);
    };

    window.addEventListener('deviceorientation', handleOrientation, true);

    // Si après 2 secondes on a pas reçu de données, on suppose que l'aperçu bloque
    timeoutId = setTimeout(() => {
      setSensorStatus(prev => {
        if (prev === 'waiting') {
          setErrorMessage("Les capteurs sont bloqués par l'aperçu. Activez le mode simulation pour tester.");
          return 'blocked';
        }
        return prev;
      });
    }, 2000);

    return () => {
      window.removeEventListener('deviceorientation', handleOrientation, true);
      clearTimeout(timeoutId);
    };
  }, [hasPermission, isSimulating]);

  useEffect(() => {
    if (isTracking && startHeading !== null) {
      const diff = calculateAngleDifference(startHeading, currentHeading);
      setAngleDiff(diff);
      if (diff > maxAngle) {
        setMaxAngle(diff);
      }
    }
  }, [currentHeading, isTracking, startHeading, maxAngle]);

  const startMeasurement = () => {
    setStartHeading(currentHeading);
    setAngleDiff(0);
    setMaxAngle(0);
    setIsTracking(true);
  };

  const stopMeasurement = () => {
    setIsTracking(false);
    setStep('result');
  };

  const resetMeasurement = () => {
    setStartHeading(null);
    setAngleDiff(0);
    setMaxAngle(0);
    setStep('measuring');
  };

  const enableSimulation = () => {
    setIsSimulating(true);
    setSensorStatus('active');
    setErrorMessage('');
    setCurrentHeading(0);
  };

  // --- ECRAN INTRO ---
  if (step === 'intro') {
    return (
      <div className="min-h-screen bg-slate-900 text-white flex flex-col items-center justify-center p-6 text-center font-sans">
        <Activity className="w-16 h-16 text-blue-500 mb-4" />
        <h1 className="text-3xl font-bold mb-4">Goniomètre de Souplesse</h1>
        <p className="text-slate-300 mb-6 text-sm max-w-sm">
          Mesurez l'angle de votre grand écart à l'aide des capteurs de votre téléphone.
        </p>

        {errorMessage && (
          <div className="bg-red-900/50 border border-red-500 text-red-200 p-4 rounded-xl mb-6 max-w-sm text-sm">
            <AlertTriangle className="inline mb-1 mr-2" size={18} />
            {errorMessage}
          </div>
        )}

        <button 
          onClick={requestAccess}
          className="bg-blue-600 hover:bg-blue-500 text-white font-bold py-4 px-8 rounded-full shadow-lg flex items-center text-lg w-full max-w-xs justify-center mb-4"
        >
          <Compass className="mr-2" /> Autoriser & Commencer
        </button>

        <p className="text-slate-500 text-xs max-w-xs mt-4">
          Note: Les capteurs nécessitent que l'application soit sur son propre site HTTPS pour fonctionner.
        </p>
      </div>
    );
  }

  // --- ECRAN RESULTAT ---
  if (step === 'result') {
    return (
      <div className="min-h-screen bg-slate-900 text-white flex flex-col items-center justify-center p-6 font-sans">
        <h2 className="text-2xl font-semibold text-slate-400 mb-4">Résultat</h2>
        
        <div className="relative w-64 h-64 flex items-center justify-center mb-8">
          <div className="absolute inset-0 rounded-full border-8 border-slate-800"></div>
          <div 
            className="absolute inset-0 rounded-full"
            style={{ background: `conic-gradient(from -90deg, #3b82f6 ${angleDiff}deg, transparent ${angleDiff}deg)`, opacity: 0.6 }}
          ></div>
          <div className="z-10 flex flex-col items-center">
            <span className="text-7xl font-black text-white">{angleDiff}°</span>
            <span className="text-slate-300">Angle final</span>
          </div>
        </div>

        <div className="bg-slate-800 rounded-xl p-6 mb-8 w-full max-w-xs text-center border border-slate-700">
           <p className="text-slate-400 text-sm">Angle d'ouverture maximum</p>
           <p className="text-3xl font-bold text-blue-400">{maxAngle}°</p>
        </div>

        <button 
          onClick={resetMeasurement}
          className="bg-slate-700 hover:bg-slate-600 text-white font-bold py-4 px-8 rounded-full shadow-lg flex items-center w-full max-w-xs justify-center text-lg"
        >
          <RotateCcw className="mr-2" /> Nouvelle Mesure
        </button>
      </div>
    );
  }

  // --- ECRAN DE MESURE ---
  return (
    <div className="min-h-screen bg-slate-900 text-white flex flex-col items-center justify-between p-6 font-sans">
      
      {/* Zone de notifications / erreurs */}
      <div className="w-full text-center mt-4">
        {sensorStatus === 'blocked' ? (
          <div className="bg-yellow-900/50 border border-yellow-600 text-yellow-200 p-3 rounded-lg text-sm mb-4">
            <AlertTriangle className="inline mr-2 mb-1" size={16} />
            Les capteurs sont bloqués par l'aperçu.
            <button onClick={enableSimulation} className="block w-full mt-2 bg-yellow-600 text-white py-2 rounded-md font-bold">
              <Settings2 className="inline mr-2" size={16}/> Activer la simulation
            </button>
          </div>
        ) : (
          <h2 className="text-lg font-medium text-slate-300">
            {isTracking ? "Pivotez vers la deuxième jambe" : "Pointez la première jambe"}
          </h2>
        )}
      </div>

      {/* Interface Visuelle (Boussole) */}
      <div className="relative w-64 h-64 flex flex-col items-center justify-center my-6">
        <div className="absolute top-0 w-2 h-6 bg-blue-500 rounded-full z-20"></div>
        
        <div 
          className="absolute inset-0 rounded-full border-4 border-slate-700 transition-transform duration-75"
          style={{ transform: `rotate(${-currentHeading}deg)` }}
        ></div>

        {isTracking && (
          <div 
            className="absolute inset-0 rounded-full"
            style={{ background: `conic-gradient(from ${-currentHeading}deg, rgba(59,130,246,0.2) ${angleDiff}deg, transparent ${angleDiff}deg)` }}
          ></div>
        )}

        <div className="z-10 flex flex-col items-center bg-slate-900 rounded-full w-40 h-40 justify-center border border-slate-800 shadow-xl">
          <span className="text-5xl font-black text-white">
            {isTracking ? angleDiff : "0"}°
          </span>
        </div>
      </div>

      {/* Curseur de simulation si activé */}
      {isSimulating && (
        <div className="w-full max-w-xs mb-6 bg-slate-800 p-4 rounded-xl border border-slate-700">
          <label className="text-xs text-slate-400 mb-2 block uppercase font-bold">Simuler la rotation du téléphone</label>
          <input 
            type="range" 
            min="0" max="360" 
            value={currentHeading} 
            onChange={(e) => setCurrentHeading(Number(e.target.value))}
            className="w-full accent-blue-500"
          />
        </div>
      )}

      {/* Boutons d'action */}
      <div className="w-full max-w-xs mb-6">
        {!isTracking ? (
          <button 
            onClick={startMeasurement}
            disabled={sensorStatus === 'waiting' && !isSimulating}
            className={`w-full font-bold py-4 px-8 rounded-full shadow-lg flex items-center justify-center text-xl transition-colors ${
              sensorStatus === 'waiting' && !isSimulating ? 'bg-slate-700 text-slate-500' : 'bg-blue-600 hover:bg-blue-500 text-white'
            }`}
          >
            <Play className="mr-3" size={24} /> {sensorStatus === 'waiting' && !isSimulating ? "Recherche..." : "Démarrer"}
          </button>
        ) : (
          <button 
            onClick={stopMeasurement}
            className="w-full bg-red-500 hover:bg-red-400 text-white font-bold py-4 px-8 rounded-full shadow-lg flex items-center justify-center text-xl"
          >
            <Square className="mr-3" size={24} /> Stop
          </button>
        )}
      </div>
    </div>
  );
}


